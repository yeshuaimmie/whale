<%- include('../partials/head', { title }) %>
<body style="padding-top:0;">
<div class="dashboard">
  <%- include('../partials/userSidebar') %>

  <div class="main-content">
    <h1 style="margin-bottom: 2rem;">Withdraw Funds</h1>
    <%- include('../partials/alerts') %>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items:start;">
      <div class="card">
        <div class="card-header">
          <h3>Request Withdrawal</h3>
        </div>

        <div style="background: #e8f5e8; color:#1b5e20; padding: 1rem; border-radius: 5px; margin-bottom: 1.5rem;">
          <h4>Available Balance (Profit + Referral Earnings)</h4>
          <p style="font-size: 2rem; color: var(--success-color);">UGX <%= Number(availableProfit).toLocaleString() %></p>
        </div>

        <form id="withdrawalForm" method="POST" action="/withdrawals">
          <div class="form-group">
            <label for="amount">Amount to Withdraw (UGX)</label>
            <input type="number" id="amount" name="amount" min="10000" max="<%= availableProfit %>" required placeholder="Enter amount">
            <small style="color: #666;">Minimum withdrawal: UGX 10,000</small>
          </div>

          <div class="form-group">
            <label for="paymentMethod">Payment Method</label>
            <select id="paymentMethod" name="paymentMethod" required>
              <option value="">Select Payment Method</option>
              <option value="mtn">MTN Mobile Money</option>
              <option value="airtel">Airtel Money</option>
              <option value="bank">Bank Transfer</option>
            </select>
          </div>

          <div class="form-group">
            <label for="phone">Mobile Money Number</label>
            <input type="tel" id="phone" name="phone" required placeholder="Enter your mobile money number" data-registered-phone="<%= currentUser.phone %>" value="<%= currentUser.phone %>">
            <div id="phoneMismatchError" style="display:none; background: linear-gradient(135deg, #fde8e8, #fcc); border-left: 4px solid #e74c3c; padding: 0.6rem 0.9rem; border-radius: 6px; margin-top: 0.5rem; align-items: center; gap: 0.5rem;">
              <i class="fas fa-times-circle" style="color: #e74c3c; flex-shrink:0;"></i>
              <small style="color: #c0392b; font-size: 0.82rem;"><strong>Error:</strong> The number entered does not match your registered mobile money number. Withdrawals can only be made to your registered number.</small>
            </div>
          </div>

          <div class="form-group">
            <label for="accountName">Account Name</label>
            <input type="text" id="accountName" name="accountName" required placeholder="Enter your full name">
          </div>

          <button type="submit" id="submitWithdrawalBtn" class="btn btn-primary" style="width: 100%;">Request Withdrawal</button>
        </form>

        <script>
          (function() {
            const phoneInput = document.getElementById('phone');
            const errorDiv = document.getElementById('phoneMismatchError');
            const submitBtn = document.getElementById('submitWithdrawalBtn');
            const registeredPhone = phoneInput?.dataset?.registeredPhone || '';

            function validatePhone() {
              const entered = phoneInput?.value?.trim();
              if (entered && entered !== registeredPhone) {
                errorDiv.style.display = 'flex';
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.5';
                submitBtn.style.cursor = 'not-allowed';
              } else {
                errorDiv.style.display = 'none';
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
                submitBtn.style.cursor = 'pointer';
              }
            }

            phoneInput?.addEventListener('input', validatePhone);

            document.getElementById('withdrawalForm')?.addEventListener('submit', function(e) {
              const entered = phoneInput?.value?.trim();
              if (entered !== registeredPhone) {
                e.preventDefault();
                errorDiv.style.display = 'flex';
                phoneInput.focus();
                return false;
              }
            });
          })();
        </script>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>Withdrawal Information</h3>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <h4 style="color: var(--primary-color); margin-bottom: 0.5rem;">Processing Time</h4>
          <p>Withdrawals are processed within 24-48 hours</p>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <h4 style="color: var(--primary-color); margin-bottom: 0.5rem;">Withdrawal Limits</h4>
          <ul style="list-style: none; padding-left: 0; margin:0;">
            <li>Minimum: UGX 10,000</li>
            <li>Maximum: UGX 5,000,000 per transaction</li>
            <li>Daily Limit: UGX 10,000,000</li>
          </ul>
        </div>

        <div style="background: #f5f5f5; color:#222; padding: 1rem; border-radius: 5px;">
          <h4 style="margin-bottom: 0.5rem;">Important Notes:</h4>
          <ul style="list-style: none; padding-left: 0; margin:0;">
            <li style="margin-bottom: 0.5rem;"><i class="fas fa-check-circle" style="color: var(--success-color);"></i> Ensure your mobile money number is correct</li>
            <li style="margin-bottom: 0.5rem;"><i class="fas fa-check-circle" style="color: var(--success-color);"></i> Withdrawals are processed manually</li>
            <li style="margin-bottom: 0.5rem;"><i class="fas fa-check-circle" style="color: var(--success-color);"></i> You'll receive SMS notification when processed</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="card" style="margin-top: 2rem;">
      <div class="card-header">
        <h3>Withdrawal History</h3>
      </div>

      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Amount</th>
              <th>Method</th>
              <th>Phone</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% withdrawals.forEach((item) => { %>
              <tr>
                <td><%= new Date(item.createdAt).toISOString().slice(0, 10) %></td>
                <td>UGX <%= Number(item.amount).toLocaleString() %></td>
                <td><%= item.paymentMethod === 'mtn' ? 'MTN Mobile Money' : item.paymentMethod === 'airtel' ? 'Airtel Money' : 'Bank Transfer' %></td>
                <td><%= item.phone %></td>
                <td><span class="status-badge status-<%= item.status === 'completed' ? 'completed' : item.status %>"><%= item.status.charAt(0).toUpperCase() + item.status.slice(1) %></span></td>
              </tr>
            <% }) %>
            <% if (!withdrawals.length) { %>
              <tr><td colspan="5">No withdrawals yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
