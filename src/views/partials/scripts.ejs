<button id="installAppBtn" class="pwa-install-btn" type="button" aria-label="Install app" hidden>
	<i class="fas fa-download" aria-hidden="true"></i>
	Install App
</button>

<div id="iosInstallHint" class="ios-install-hint" hidden>
	<div class="ios-install-card" role="dialog" aria-label="Install on iPhone">
		<strong>Install on iPhone</strong>
		<p>Add this app to your Home Screen:</p>
		<ol>
			<li>Tap the Share button in Safari.</li>
			<li>Select Add to Home Screen.</li>
			<li>Tap Add to finish installation.</li>
		</ol>
		<button id="iosInstallDismiss" type="button" class="ios-install-dismiss">Got it</button>
	</div>
</div>

<div id="androidInstallHint" class="ios-install-hint" hidden>
	<div class="ios-install-card" role="dialog" aria-label="Install on Android">
		<strong>Install on Android</strong>
		<p>Add this app to your device:</p>
		<ol>
			<li>Tap the Install App button.</li>
			<li>Confirm the install prompt.</li>
			<li>Open the app from your home screen.</li>
		</ol>
		<button id="androidInstallDismiss" type="button" class="ios-install-dismiss">Got it</button>
	</div>
</div>

<script src="/js/main.js"></script>
<script>
	(function setupPWA() {
		const supportsServiceWorker = 'serviceWorker' in navigator;
		const installBtn = document.getElementById('installAppBtn');
		const iosInstallHint = document.getElementById('iosInstallHint');
		const iosInstallDismiss = document.getElementById('iosInstallDismiss');
		const androidInstallHint = document.getElementById('androidInstallHint');
		const androidInstallDismiss = document.getElementById('androidInstallDismiss');
		let deferredInstallPrompt = null;

		const ua = window.navigator.userAgent || '';
		const isIOS = /iphone|ipad|ipod/i.test(ua);
		const isAndroid = /android/i.test(ua);
		const isSafari = /safari/i.test(ua) && !/crios|fxios|edgios|opios/i.test(ua);
		const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;

		if (iosInstallDismiss) {
			iosInstallDismiss.addEventListener('click', () => {
				if (iosInstallHint) iosInstallHint.hidden = true;
			});
		}

		if (androidInstallDismiss) {
			androidInstallDismiss.addEventListener('click', () => {
				if (androidInstallHint) androidInstallHint.hidden = true;
			});
		}

		if (isIOS && isSafari && !isStandalone && iosInstallHint) {
			iosInstallHint.hidden = false;
		}

		if (isAndroid && !isStandalone && androidInstallHint) {
			androidInstallHint.hidden = false;
		}

		window.addEventListener('beforeinstallprompt', (event) => {
			event.preventDefault();
			deferredInstallPrompt = event;
			if (installBtn) installBtn.hidden = false;
		});

		if (installBtn) {
			installBtn.addEventListener('click', async () => {
				if (!deferredInstallPrompt) return;
				deferredInstallPrompt.prompt();
				await deferredInstallPrompt.userChoice;
				deferredInstallPrompt = null;
				installBtn.hidden = true;
			});
		}

		window.addEventListener('appinstalled', () => {
			deferredInstallPrompt = null;
			if (installBtn) installBtn.hidden = true;
			if (iosInstallHint) iosInstallHint.hidden = true;
			if (androidInstallHint) androidInstallHint.hidden = true;
		});

		if (supportsServiceWorker) {
			window.addEventListener('load', () => {
				navigator.serviceWorker.register('/service-worker.js').catch(() => {
					// Ignore registration failures silently to avoid breaking UX.
				});
			});
		}
	})();
</script>
<style>
	.pwa-install-btn {
		position: fixed;
		right: 1rem;
		bottom: 1rem;
		z-index: 1100;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border: none;
		border-radius: 999px;
		padding: 0.75rem 1rem;
		font-size: 0.95rem;
		font-weight: 600;
		background: #1a7f37;
		color: #fff;
		cursor: pointer;
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
	}

	.pwa-install-btn:hover {
		background: #166b2f;
	}

	.pwa-install-btn[hidden] {
		display: none;
	}

	.ios-install-hint {
		position: fixed;
		left: 1rem;
		right: 1rem;
		bottom: 1rem;
		z-index: 1090;
		display: flex;
		justify-content: center;
	}

	.ios-install-hint[hidden] {
		display: none;
	}

	#androidInstallHint {
		bottom: 6.2rem;
	}

	.ios-install-card {
		width: min(100%, 380px);
		background: #ffffff;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 14px;
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
		padding: 0.9rem 1rem;
	}

	.ios-install-card strong {
		display: block;
		margin-bottom: 0.25rem;
		color: #1f2937;
	}

	.ios-install-card p {
		margin: 0 0 0.45rem;
		font-size: 0.9rem;
		color: #4b5563;
	}

	.ios-install-card ol {
		margin: 0 0 0.7rem 1.15rem;
		padding: 0;
		color: #374151;
		font-size: 0.9rem;
		line-height: 1.4;
	}

	.ios-install-dismiss {
		border: none;
		background: #0f766e;
		color: #fff;
		padding: 0.5rem 0.8rem;
		border-radius: 8px;
		font-weight: 600;
		cursor: pointer;
	}

	.ios-install-dismiss:hover {
		background: #0b625b;
	}

	@media (max-width: 640px) {
		.pwa-install-btn {
			right: 0.75rem;
			bottom: 0.75rem;
			font-size: 0.9rem;
			padding: 0.7rem 0.95rem;
		}

		.ios-install-hint {
			left: 0.7rem;
			right: 0.7rem;
			bottom: 3.7rem;
		}
	}
</style>
</body>
</html>
