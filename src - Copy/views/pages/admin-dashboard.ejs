<%- include('../partials/head', { title }) %>
<body style="padding-top: 0;">
<div class="dashboard">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>
    <div class="page-toolbar">
      <h1 style="font-size: clamp(1.3rem, 5vw, 1.8rem);">Admin Dashboard</h1>
      <div class="inline-balance"><i class="fas fa-clock"></i> Last updated: <span id="currentTime"></span></div>
    </div>

    <div class="stats-grid">
      <div class="stat-card"><div class="stat-info"><h3>Total Users</h3><p style="font-size: clamp(1.2rem, 4vw, 1.8rem);"><%= metrics.usersCount %></p></div><div class="stat-icon" style="background: #e3f2fd; color: #1976d2;"><i class="fas fa-users"></i></div></div>
      <div class="stat-card"><div class="stat-info"><h3>Total Deposits</h3><p style="font-size: clamp(1.2rem, 4vw, 1.8rem);">UGX <%= Number(metrics.totalDeposited).toLocaleString() %></p></div><div class="stat-icon" style="background: #e8f5e8; color: #388e3c;"><i class="fas fa-money-bill-wave"></i></div></div>
      <div class="stat-card"><div class="stat-info"><h3>Active Investments</h3><p style="font-size: clamp(1.2rem, 4vw, 1.8rem);"><%= metrics.investmentsCount %></p></div><div class="stat-icon" style="background: #fff3e0; color: #f57c00;"><i class="fas fa-chart-line"></i></div></div>
      <div class="stat-card"><div class="stat-info"><h3>Pending Withdrawals</h3><p style="font-size: clamp(1.2rem, 4vw, 1.8rem);"><%= metrics.pendingWithdrawalsCount %></p></div><div class="stat-icon" style="background: #f3e5f5; color: #7b1fa2;"><i class="fas fa-clock"></i></div></div>
    </div>

    <div class="flex-grid-2" style="margin-bottom: 2rem;">
      <div class="card">
        <div class="card-header"><h3>Pending Deposits</h3><a href="/admin/deposits" class="btn btn-primary btn-sm">View All</a></div>
        <div class="table-responsive">
          <table>
            <thead><tr><th>User</th><th>Amount</th><th>Method</th><th>Action</th></tr></thead>
            <tbody>
              <% pendingDeposits.forEach((item) => { %>
              <tr>
                <td><%= item.user?.fullName || '-' %></td>
                <td>UGX <%= Number(item.amount).toLocaleString() %></td>
                <td style="text-transform:uppercase;"><%= item.paymentMethod %></td>
                <td>
                  <div class="table-actions">
                    <form method="POST" action="/admin/deposits/<%= item._id %>"><input type="hidden" name="status" value="approved"><button class="action-btn btn-approve">Approve</button></form>
                    <form method="POST" action="/admin/deposits/<%= item._id %>"><input type="hidden" name="status" value="rejected"><button class="action-btn btn-reject">Reject</button></form>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% if (!pendingDeposits.length) { %><tr><td colspan="4">No pending deposits.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>Pending Withdrawals</h3><a href="/admin/withdrawals" class="btn btn-primary btn-sm">View All</a></div>
        <div class="table-responsive">
          <table>
            <thead><tr><th>User</th><th>Amount</th><th>Method</th><th>Action</th></tr></thead>
            <tbody>
              <% pendingWithdrawals.forEach((item) => { %>
              <tr>
                <td><%= item.user?.fullName || '-' %></td>
                <td>UGX <%= Number(item.amount).toLocaleString() %></td>
                <td style="text-transform:uppercase;"><%= item.paymentMethod %></td>
                <td>
                  <div class="table-actions">
                    <form method="POST" action="/admin/withdrawals/<%= item._id %>"><input type="hidden" name="status" value="processing"><button class="action-btn btn-process">Process</button></form>
                    <form method="POST" action="/admin/withdrawals/<%= item._id %>"><input type="hidden" name="status" value="failed"><button class="action-btn btn-reject">Reject</button></form>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% if (!pendingWithdrawals.length) { %><tr><td colspan="4">No pending withdrawals.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h3>Recent Investments</h3><a href="/admin/investments" class="btn btn-primary btn-sm">View All</a></div>
      <div class="table-responsive">
        <table>
          <thead><tr><th>User</th><th>Plan</th><th>Amount</th><th>Daily Profit</th><th>Start Date</th><th>End Date</th><th>Status</th></tr></thead>
          <tbody>
            <% recentInvestments.forEach((item) => { %>
            <tr>
              <td><%= item.user?.fullName || '-' %></td>
              <td><%= item.plan?.name || 'Plan' %></td>
              <td>UGX <%= Number(item.principal).toLocaleString() %></td>
              <td>UGX <%= Number(item.principal * (item.dailyRate / 100)).toLocaleString() %></td>
              <td><%= new Date(item.startDate).toLocaleDateString() %></td>
              <td><%= new Date(item.endDate).toLocaleDateString() %></td>
              <td><span class="status-badge status-<%= item.status === 'completed' ? 'completed' : 'active' %>"><%= item.status %></span></td>
            </tr>
            <% }) %>
            <% if (!recentInvestments.length) { %><tr><td colspan="7">No investments yet.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="summary-grid" style="margin-top: 2rem;">
      <div class="card" style="text-align:center;"><h3 style="color:#666; font-size:0.95rem;">Today's Deposits</h3><p style="font-size: clamp(1.2rem, 4vw, 2rem); color: var(--primary-color);">UGX <%= Number(metrics.depositsToday).toLocaleString() %></p></div>
      <div class="card" style="text-align:center;"><h3 style="color:#666; font-size:0.95rem;">Today's Withdrawals</h3><p style="font-size: clamp(1.2rem, 4vw, 2rem); color: var(--danger-color);">UGX <%= Number(metrics.withdrawalsToday).toLocaleString() %></p></div>
      <div class="card" style="text-align:center;"><h3 style="color:#666; font-size:0.95rem;">New Users Today</h3><p style="font-size: clamp(1.2rem, 4vw, 2rem); color: var(--secondary-color);"><%= metrics.newUsersToday %></p></div>
      <div class="card" style="text-align:center;"><h3 style="color:#666; font-size:0.95rem;">Total Profit Paid</h3><p style="font-size: clamp(1.2rem, 4vw, 2rem); color: var(--success-color);">UGX <%= Number(metrics.totalProfitPaid).toLocaleString() %></p></div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
<script>
function updateTime() { document.getElementById('currentTime').textContent = new Date().toLocaleString(); }
updateTime(); setInterval(updateTime, 1000);
</script>
