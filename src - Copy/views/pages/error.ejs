<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body style="padding-top:60px;">
<nav class="navbar"><div class="container"><a href="/" class="logo">The Whale Investors</a></div></nav>
<div style="min-height: calc(100vh - 140px); display:flex; align-items:center; justify-content:center; padding:1.5rem;">
  <div class="card" style="max-width: 560px; width: 100%;">
    <div class="card-header"><h2 style="color: var(--primary-color);"><%= title %></h2></div>
    <div class="alert alert-danger" style="display:block;"><%= message %></div>
    <div style="margin-top: 1rem; display:flex; gap: .75rem; flex-wrap:wrap;">
      <a href="javascript:history.back()" class="btn btn-primary">Go Back</a>
      <a href="/" class="btn btn-secondary">Go Home</a>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>