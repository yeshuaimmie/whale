<%- include('../partials/head', { title }) %>
<body style="padding-top: 0;">
<div class="dashboard">
  <%- include('../partials/adminSidebar') %>

  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
      <h1 style="font-size: clamp(1.3rem, 5vw, 1.8rem);">Deposit Management</h1>
      <div class="inline-balance">
        <i class="fas fa-clock"></i> Last updated: <span id="currentTime"></span>
      </div>
    </div>

    <div class="summary-card">
      <h3 style="margin-bottom: 1rem; text-align: center;">Deposit Summary</h3>
      <div class="summary-grid">
        <div class="summary-item">
          <div class="summary-value" id="totalDeposits">UGX <%= Number(summary.totalAmount).toLocaleString() %></div>
          <div class="summary-label">Total Deposits</div>
        </div>
        <div class="summary-item">
          <div class="summary-value" id="pendingDeposits"><%= summary.pendingCount %></div>
          <div class="summary-label">Pending</div>
        </div>
        <div class="summary-item">
          <div class="summary-value" id="approvedDeposits"><%= summary.approvedCount %></div>
          <div class="summary-label">Approved</div>
        </div>
        <div class="summary-item">
          <div class="summary-value" id="todayDeposits">UGX <%= Number(summary.todayAmount).toLocaleString() %></div>
          <div class="summary-label">Today</div>
        </div>
      </div>
    </div>

    <div class="search-container">
      <input type="text" id="searchInput" class="search-input" placeholder="Search by name, email, or transaction ID...">
      <select id="statusFilter" class="filter-select">
        <option value="">All Status</option>
        <option value="pending">Pending</option>
        <option value="approved">Approved</option>
        <option value="rejected">Rejected</option>
        <option value="processing">Processing</option>
      </select>
      <select id="methodFilter" class="filter-select">
        <option value="">All Methods</option>
        <option value="mtn">MTN Mobile Money</option>
        <option value="airtel">Airtel Money</option>
        <option value="bank">Bank Transfer</option>
      </select>
    </div>

    <div class="card">
      <div class="card-header">
        <h3>Deposit Requests</h3>
        <div style="display: flex; gap: 0.5rem;">
          <button class="btn btn-sm btn-secondary" type="button" onclick="exportDeposits()">
            <i class="fas fa-download"></i> Export
          </button>
          <button class="btn btn-sm btn-primary" type="button" onclick="refreshDeposits(this)">
            <i class="fas fa-sync"></i> Refresh
          </button>
        </div>
      </div>

      <div class="table-container">
        <table id="depositsTable">
          <thead>
            <tr>
              <th>User</th>
              <th>Amount</th>
              <th>Method</th>
              <th>Reference</th>
              <th>Date</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% deposits.forEach((item) => { %>
              <tr data-search="<%= `${item.user?.fullName || ''} ${item.user?.email || ''} ${item.reference}`.toLowerCase() %>" data-status="<%= item.status %>" data-method="<%= item.paymentMethod %>">
                <td>
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <div class="profile-avatar"><%= (item.user?.fullName || 'U').charAt(0).toUpperCase() %></div>
                    <div>
                      <div style="font-weight: 500;"><%= item.user?.fullName || '-' %></div>
                      <div style="font-size: 0.8rem; color: #666;"><%= item.user?.email || '-' %></div>
                    </div>
                  </div>
                </td>
                <td style="font-weight: 600; color: var(--primary-color);">UGX <%= Number(item.amount).toLocaleString() %></td>
                <td>
                  <% if (item.paymentMethod === 'mtn') { %><i class="fas fa-mobile-alt mtn-color"></i> MTN Money<% } %>
                  <% if (item.paymentMethod === 'airtel') { %><i class="fas fa-mobile-alt airtel-color"></i> Airtel Money<% } %>
                  <% if (item.paymentMethod === 'bank') { %><i class="fas fa-university"></i> Bank Transfer<% } %>
                </td>
                <td style="font-family: monospace;"><%= item.reference %></td>
                <td><%= new Date(item.createdAt).toLocaleString() %></td>
                <td><span class="status-badge status-<%= item.status %>"><%= item.status %></span></td>
                <td>
                  <div class="table-actions">
                    <% if (item.status !== 'approved') { %>
                      <form method="POST" action="/admin/deposits/<%= item._id %>">
                        <input type="hidden" name="status" value="approved">
                        <button class="action-btn btn-approve" type="submit"><i class="fas fa-check"></i> Approve</button>
                      </form>
                    <% } %>
                    <% if (item.status !== 'rejected') { %>
                      <form method="POST" action="/admin/deposits/<%= item._id %>">
                        <input type="hidden" name="status" value="rejected">
                        <button class="action-btn btn-reject" type="submit"><i class="fas fa-times"></i> Reject</button>
                      </form>
                    <% } %>
                    <button class="action-btn btn-view" type="button" onclick='viewDepositDetails(<%- JSON.stringify({
                      user: item.user?.fullName || "-",
                      email: item.user?.email || "-",
                      amount: `UGX ${Number(item.amount).toLocaleString()}`,
                      method: item.paymentMethod === "mtn" ? "MTN Mobile Money" : item.paymentMethod === "airtel" ? "Airtel Money" : "Bank Transfer",
                      phone: item.phone || "-",
                      reference: item.reference,
                      date: new Date(item.createdAt).toLocaleString(),
                      status: item.status,
                      notes: item.reviewedAt ? `Reviewed ${new Date(item.reviewedAt).toLocaleString()}` : "Awaiting review",
                      proof: item.proof?.url || ""
                    }) %>)'>
                      <i class="fas fa-eye"></i> View
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
            <% if (!deposits.length) { %>
              <tr><td colspan="7">No deposit requests found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="depositModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 id="modalTitle">Deposit Details</h3>
      <span class="close" onclick="closeModal()">&times;</span>
    </div>
    <div id="modalBody"></div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
function updateTime() {
  const now = new Date();
  document.getElementById('currentTime').textContent = now.toLocaleString();
}
updateTime();
setInterval(updateTime, 1000);

const searchInput = document.getElementById('searchInput');
const statusFilter = document.getElementById('statusFilter');
const methodFilter = document.getElementById('methodFilter');

function filterDeposits() {
  const searchTerm = searchInput.value.toLowerCase();
  const status = statusFilter.value;
  const method = methodFilter.value;

  document.querySelectorAll('#depositsTable tbody tr').forEach((row) => {
    const matchesSearch = (row.dataset.search || '').includes(searchTerm);
    const matchesStatus = !status || row.dataset.status === status;
    const matchesMethod = !method || row.dataset.method === method;
    row.style.display = matchesSearch && matchesStatus && matchesMethod ? '' : 'none';
  });

  updateSummary();
}

searchInput?.addEventListener('input', filterDeposits);
statusFilter?.addEventListener('change', filterDeposits);
methodFilter?.addEventListener('change', filterDeposits);

function parseAmount(text) {
  return Number(String(text).replace(/[^\d]/g, '')) || 0;
}

function updateSummary() {
  const rows = Array.from(document.querySelectorAll('#depositsTable tbody tr')).filter((row) => row.style.display !== 'none');
  let total = 0;
  let pending = 0;
  let approved = 0;

  rows.forEach((row) => {
    const amount = parseAmount(row.cells[1].textContent);
    const status = row.cells[5].textContent.trim().toLowerCase();
    total += amount;
    if (status.includes('pending')) pending += 1;
    if (status.includes('approved')) approved += 1;
  });

  document.getElementById('totalDeposits').textContent = `UGX ${total.toLocaleString()}`;
  document.getElementById('pendingDeposits').textContent = pending;
  document.getElementById('approvedDeposits').textContent = approved;
}

function viewDepositDetails(data) {
  document.getElementById('modalTitle').textContent = `Deposit Details - ${data.reference}`;
  document.getElementById('modalBody').innerHTML = `
    <div style="display: grid; gap: 1rem;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div><strong>User Name:</strong> ${data.user}</div>
        <div><strong>Email:</strong> ${data.email}</div>
        <div><strong>Phone:</strong> ${data.phone}</div>
        <div><strong>Amount:</strong> ${data.amount}</div>
        <div><strong>Method:</strong> ${data.method}</div>
        <div><strong>Reference:</strong> ${data.reference}</div>
        <div><strong>Date:</strong> ${data.date}</div>
        <div><strong>Status:</strong> <span class="status-badge status-${data.status}">${data.status}</span></div>
      </div>
      <div><strong>Notes:</strong> ${data.notes}</div>
      ${data.proof ? `<div><strong>Proof:</strong><br><a href="${data.proof}" target="_blank" rel="noopener">Open proof image</a></div>` : '<div><strong>Proof:</strong> No proof uploaded</div>'}
    </div>
  `;
  document.getElementById('depositModal').classList.add('active');
}

function closeModal() {
  document.getElementById('depositModal').classList.remove('active');
}

function exportDeposits() {
  window.print();
}

function refreshDeposits(button) {
  const original = button.innerHTML;
  button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
  setTimeout(() => window.location.reload(), 500);
  setTimeout(() => { button.innerHTML = original; }, 1500);
}

updateSummary();
</script>
